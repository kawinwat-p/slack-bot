# Slack app credentials (https://api.slack.com/apps)
# Socket Mode: no public URL needed.
SLACK_BOT_TOKEN=xoxb-...        # OAuth & Permissions > Bot User OAuth Token
SLACK_APP_TOKEN=xapp-...        # Basic Information > App-Level Token (connections:write)
SLACK_SIGNING_SECRET=...        # Basic Information > Signing Secret

# OpenRouter (https://openrouter.ai/keys) — OpenAI-compatible endpoint
OPENROUTER_API_KEY=sk-or-...
# Pick a slug that exists in YOUR account at https://openrouter.ai/models
OPENROUTER_MODEL=anthropic/claude-opus-4.8-fast   # or anthropic/claude-opus-4.8, openai/gpt-5.5, google/gemini-3.5-flash
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1   # override only if needed
# OPENROUTER_SITE_URL=https://your-site.example       # optional, for OpenRouter attribution

# Embeddings — used for RAG when a /workflow-ideas prompt is given (no prompt = latest 1000
# messages, no embeddings needed). OpenRouter has NO embeddings endpoint, so set a separate
# OpenAI-compatible provider. Without a key, the prompt path falls back to the latest 1000.
# --- OpenAI (default) ---
# EMBEDDING_API_KEY=sk-...
# EMBEDDING_BASE_URL=https://api.openai.com/v1
# EMBEDDING_MODEL=text-embedding-3-small
# --- Gemini (Google) via its OpenAI-compatible endpoint ---
EMBEDDING_API_KEY=AIza...                                          # Google AI Studio key
EMBEDDING_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
EMBEDDING_MODEL=gemini-embedding-001
EMBEDDING_BATCH=100                                                # Gemini caps batches lower than OpenAI
