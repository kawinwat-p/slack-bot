{
  "name": "workflow-ideas-bot",
  "version": "0.1.0",
  "description": "Agentic Slack bot that deep-interviews a user from real channel context and proposes buildable workflow ideas.",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/app.ts",
    "start": "tsx src/app.ts",
    "typecheck": "tsc --noEmit",
    "test": "node --experimental-strip-types --experimental-loader ./resolve-hook.mjs verify.ts",
    "build": "tsc"
  },
  "dependencies": {
    "@slack/bolt": "^3.21.0",
    "dotenv": "^16.4.5",
    "openai": "^4.67.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0"
  }
}
